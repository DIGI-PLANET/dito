# Gateway env — copy to .env for local dev
# (.env auto-loaded by dotenvy at startup)

# ── HTTP server ──────────────────────────────────────────────
PORT=8080
RUST_LOG=info
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Supabase (PostgREST via SUPABASE_SERVICE_KEY) ────────────
# Get these from Supabase dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Auth ─────────────────────────────────────────────────────
# JWT secret — must match what Next.js uses to sign DITO_API_TOKEN.
# Use a strong random in prod; for local dev anything works.
DITO_JWT_SECRET=dev-secret-change-me
ROY_ADMIN_TOKEN=admin-dev
ADMIN_API_KEY=admin-api-dev

# ── LLM providers (optional — chat falls back to mock without these) ──
GEMINI_API_KEY=
GROQ_API_KEY=
